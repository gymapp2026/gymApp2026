# Base URL de la app (en Vercel se pone automático, pero ponelo igual)
NEXTAUTH_URL=https://tu-app.vercel.app

# Secret para NextAuth — generá uno random en: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=pon-un-string-random-largo-aqui

# MongoDB Atlas connection string
# Creá un cluster gratis en https://cloud.mongodb.com
# Formato: mongodb+srv://usuario:password@cluster.mongodb.net/gymapp
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/gymapp

# Resend API Key para emails (reset de contraseña)
# Creá cuenta gratis en https://resend.com y generá una API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx

# Email desde el que se mandan los mails (debe estar verificado en Resend)
EMAIL_FROM=noreply@tudominio.com
